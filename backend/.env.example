# Django Settings
SECRET_KEY=your-production-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL Database (set USE_SQLITE=True for local dev without MySQL)
USE_SQLITE=False
DB_NAME=pet_rescue
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Email (development uses console backend)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@petrescue.local

# LLM (OpenAI-compatible: iFlytek MaaS / OpenAI / DeepSeek)
# iFlytek: APIKey as apikey:secret from console; model id from service card or GET {base}/models
LLM_API_BASE=https://maas-api.cn-huabei-1.xf-yun.com/v2
LLM_API_KEY=
LLM_MODEL=xop3qwen1b7

# iFlytek object recognition (optional)
XFYUN_OBJECT_APP_ID=
XFYUN_OBJECT_API_KEY=
XFYUN_OBJECT_API_URL=http://tupapi.xfyun.cn/v1/currency
