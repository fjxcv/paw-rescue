# Force UTF-8 text normalization in Git (avoids GBK commits on Windows)
* text=auto eol=lf

*.js   text encoding=utf-8
*.jsx  text encoding=utf-8
*.ts   text encoding=utf-8
*.tsx  text encoding=utf-8
*.json text encoding=utf-8
*.html text encoding=utf-8
*.css  text encoding=utf-8
*.md   text encoding=utf-8
*.py   text encoding=utf-8

*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.ico  binary
*.woff binary
*.woff2 binary
